// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuarios {
  id          Int      @id @default(autoincrement())
  nombre      String
  email       String   @unique
  contrasenia String
  telefono    String
  createdAt   DateTime @default(now())
  rol         Rol      @default(CLIENTE)

  turnos Turno[] @relation("Turnos")
}

model Servicios {
  id          Int     @id @default(autoincrement())
  nombre      String
  descripcion String
  categoria   String
  precio      Float
  duracion    Int
  activo      Boolean @default(true)

  turnos Turno[]
}

model Turno {
  id        Int      @id @default(autoincrement())
  fechaHora DateTime
  estado    Estado   @default(PENDIENTE)

  estadoPago    EstadoPago @default(PENDIENTE)
  transaccionId String?

  recordatorioEnviado Boolean @default(false)

  clienteId Int?
  cliente   Usuarios? @relation("Turnos", fields: [clienteId], references: [id])

  clienteManual String?

  servicioId Int
  servicio   Servicios @relation(fields: [servicioId], references: [id])
}

model WhatsappSession {
  id        String   @id
  data      Bytes // 👉 Almacena el archivo comprimido de la sesión
  updatedAt DateTime @updatedAt
}

enum Estado {
  PENDIENTE
  CONFIRMADO
  CANCELADO
  COMPLETADO
}

enum Rol {
  ADMIN
  CLIENTE
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  REEMBOLSADO
}
